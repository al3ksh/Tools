# Admin password for the dashboard (change this!)
ADMIN_PASSWORD=changeme

# JWT signing secret for admin session cookies (required)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
ADMIN_JWT_SECRET=replace-with-a-long-random-secret

# Public URL for OG embeds and generated links (e.g. https://tools.yourdomain.com)
BASE_URL=

# Allowed web origins for CORS (comma-separated)
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Set to true only when running behind a trusted reverse proxy that sets X-Forwarded-* headers
TRUST_PROXY=false

# Max concurrent in-API heavy tasks (PDF/GIF/clip finalize). Keep 1 for Raspberry Pi 4 stability.
API_HEAVY_CONCURRENCY=1

# How long the worker waits for the API to create/migrate the SQLite schema before exiting.
DB_SCHEMA_WAIT_MS=60000
