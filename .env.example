# Admin password for the dashboard (change this!)
ADMIN_PASSWORD=changeme

# JWT signing secret for admin session cookies (required)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
ADMIN_JWT_SECRET=replace-with-a-long-random-secret

# Public URL for OG embeds and generated links (e.g. https://tools.yourdomain.com)
BASE_URL=

# Allowed web origins for CORS (comma-separated)
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
